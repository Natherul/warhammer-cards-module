        "success": [
          {
            "symbolAmount": 1,
            "description": "<p>Place any one die from your dice pool on this card, being careful to preserve its rolled face. This action card does not recharge while that die is on it. When a member of your party within medium range makes a check that includes a die of that type in its dice pool, he may take the die on this card and place it in his results pool instead of rolling that particular die</p>"
          }
        ],
        "boon": [
          {
            "symbolAmount": 2,
            "description": "<p>You may add a second die from the dice pool to this card. This card doesn't recharge until both dice are spent. Both dice can be spent on the same check, or used on different checks</p>"
          }
        ],
